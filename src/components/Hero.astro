---
---

<section class="hero" id="hero">

  <!-- Animated background rings -->
  <div class="hero__rings" aria-hidden="true">
    <div class="ring ring--1"></div>
    <div class="ring ring--2"></div>
    <div class="ring ring--3"></div>
    <div class="ring ring--4"></div>
  </div>

  <!-- Central Logo Mark (Large) -->
  <div class="hero__logo-mark" aria-hidden="true">
    <svg class="hero__logo-svg" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Outer orbit ring -->
      <circle cx="100" cy="100" r="90" stroke="#0E3B8C" stroke-width="0.5" stroke-dasharray="4 6" opacity="0.4"/>
      <!-- Inner orbit ring -->
      <circle cx="100" cy="100" r="65" stroke="#B4B9C1" stroke-width="0.5" stroke-dasharray="2 4" opacity="0.25"/>

      <!-- Interlocking loop LEFT -->
      <ellipse
        cx="80"
        cy="100"
        rx="45"
        ry="28"
        stroke="#B4B9C1"
        stroke-width="2"
        fill="none"
        transform="rotate(-15 80 100)"
        opacity="0.9"
      />
      <!-- Interlocking loop RIGHT -->
      <ellipse
        cx="120"
        cy="100"
        rx="45"
        ry="28"
        stroke="#B4B9C1"
        stroke-width="2"
        fill="none"
        transform="rotate(15 120 100)"
        opacity="0.9"
      />

      <!-- Letter A -->
      <path
        d="M100 52L128 148H115L100 100L85 148H72L100 52Z"
        fill="#0E3B8C"
      />
      <line x1="82" y1="120" x2="118" y2="120" stroke="#0E3B8C" stroke-width="4" stroke-linecap="round"/>

      <!-- Orbiting nodes -->
      <circle class="orbit-node orbit-node--1" cx="100" cy="10" r="4" fill="#1a52c4" opacity="0.9"/>
      <circle class="orbit-node orbit-node--2" cx="190" cy="100" r="3" fill="#B4B9C1" opacity="0.7"/>
      <circle class="orbit-node orbit-node--3" cx="100" cy="190" r="4" fill="#1a52c4" opacity="0.9"/>
    </svg>
  </div>

  <!-- Content -->
  <div class="container hero__content">
    <div class="hero__eyebrow">
      <span class="hero__eyebrow-dot"></span>
      <span class="mono" style="font-size: 0.72rem; letter-spacing: 0.2em; color: var(--cobalt-light);">
        ANVAYA HYBRID STACK — v0.1 EARLY ACCESS
      </span>
    </div>

    <h1 class="hero__headline">
      Quantum Computing.<br/>
      <span class="gradient-text">From Pulse to Platform.</span>
    </h1>

    <p class="hero__sub">
      The first integrated quantum development stack that bridges microsecond
      bare-metal control with millisecond human interaction — without compromise.
      Build, simulate, and orchestrate quantum circuits at every layer.
    </p>

    <!-- Stats bar -->
    <div class="hero__stats">
      <div class="hero__stat">
        <span class="hero__stat-value mono">~20+</span>
        <span class="hero__stat-label">Qubit Local Sim</span>
      </div>
      <div class="hero__stat-divider"></div>
      <div class="hero__stat">
        <span class="hero__stat-value mono">&lt;1μs</span>
        <span class="hero__stat-label">QEC Loop Latency</span>
      </div>
      <div class="hero__stat-divider"></div>
      <div class="hero__stat">
        <span class="hero__stat-value mono">3</span>
        <span class="hero__stat-label">Integrated Layers</span>
      </div>
      <div class="hero__stat-divider"></div>
      <div class="hero__stat">
        <span class="hero__stat-value mono">Wasm</span>
        <span class="hero__stat-label">Browser-Native Speed</span>
      </div>
    </div>

    <!-- CTAs -->
    <div class="hero__ctas">
      <a href="#waitlist" class="btn btn--primary btn--lg">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M8 1L15 8L8 15M15 8H1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Request Early Access
      </a>
      <a href="#architecture" class="btn btn--outline btn--lg">
        Explore Architecture
      </a>
    </div>

    <!-- Terminal preview -->
    <div class="hero__terminal" aria-label="Code preview">
      <div class="terminal__header">
        <div class="terminal__dots">
          <span style="background:#ff5f57"></span>
          <span style="background:#ffbd2e"></span>
          <span style="background:#28c840"></span>
        </div>
        <span class="terminal__title mono">anvaya-core — circuit_builder.rs</span>
      </div>
      <div class="terminal__body">
        <pre class="terminal__code"><code><span class="t-comment">// ANVAYA Core — Circuit Optimization Engine</span>
<span class="t-keyword">use</span> anvaya_core::{Circuit, Gate, Optimizer};
<span class="t-keyword">use</span> rayon::prelude::<span class="t-type">*</span>;

<span class="t-keyword">fn</span> <span class="t-fn">optimize_and_dispatch</span>(circuit: Circuit) <span class="t-op">-&gt;</span> <span class="t-type">Result</span>&lt;PulseSequence&gt; {
    <span class="t-comment">// Parallel gate reduction — preserve qubit coherence</span>
    <span class="t-keyword">let</span> optimized = circuit
        .gates()
        .par_iter()
        .filter(|g| !g.is_identity())
        .<span class="t-fn">reduce_commuting_pairs</span>()
        .<span class="t-fn">collect</span>::&lt;Circuit&gt;();

    <span class="t-comment">// Dispatch to ANVAYA Pulse — deterministic timing</span>
    Pulse::<span class="t-fn">dispatch</span>(optimized, Timing::Nanosecond(<span class="t-num">50</span>))
}<span class="t-cursor"></span></code></pre>
      </div>
    </div>

  </div>

  <!-- Scroll indicator -->
  <div class="hero__scroll">
    <div class="hero__scroll-line"></div>
    <span class="mono" style="font-size:0.6rem; letter-spacing:0.15em; color:var(--muted-grey);">SCROLL</span>
  </div>

</section>

<style>
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  padding-top: 68px;
}

/* Rings */
.hero__rings {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.ring {
  position: absolute;
  border-radius: 50%;
  border: 1px solid rgba(14, 59, 140, 0.12);
}

.ring--1 {
  width: 320px;
  height: 320px;
  animation: pulse-ring 4s ease-in-out infinite;
}
.ring--2 {
  width: 520px;
  height: 520px;
  animation: pulse-ring 4s ease-in-out infinite 0.8s;
  border-color: rgba(14, 59, 140, 0.08);
}
.ring--3 {
  width: 720px;
  height: 720px;
  animation: pulse-ring 4s ease-in-out infinite 1.6s;
  border-color: rgba(14, 59, 140, 0.05);
}
.ring--4 {
  width: 960px;
  height: 960px;
  animation: pulse-ring 4s ease-in-out infinite 2.4s;
  border-color: rgba(14, 59, 140, 0.03);
}

/* Logo mark behind content */
.hero__logo-mark {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: min(480px, 90vw);
  height: min(480px, 90vw);
  opacity: 0.12;
  pointer-events: none;
}

.hero__logo-svg {
  width: 100%;
  height: 100%;
  animation: spin-slow 60s linear infinite;
}

/* Content */
.hero__content {
  position: relative;
  z-index: 2;
  text-align: center;
  padding-top: 4rem;
  padding-bottom: 4rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1.75rem;
}

/* Eyebrow */
.hero__eyebrow {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  background: rgba(14, 59, 140, 0.1);
  border: 1px solid rgba(14, 59, 140, 0.25);
  border-radius: 100px;
  padding: 0.4rem 1rem;
}

.hero__eyebrow-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--cobalt-light);
  animation: pulse-ring 2s ease-in-out infinite;
  box-shadow: 0 0 8px var(--cobalt-light);
  flex-shrink: 0;
}

/* Headline */
.hero__headline {
  font-size: clamp(2.8rem, 7vw, 5.5rem);
  font-weight: 700;
  letter-spacing: -0.03em;
  line-height: 1.1;
  max-width: 820px;
}

/* Sub */
.hero__sub {
  font-size: clamp(1rem, 2vw, 1.2rem);
  color: var(--muted-grey);
  max-width: 620px;
  line-height: 1.8;
}

/* Stats */
.hero__stats {
  display: flex;
  align-items: center;
  gap: 0;
  background: rgba(17, 27, 36, 0.6);
  border: 1px solid var(--border-subtle);
  border-radius: 10px;
  overflow: hidden;
}

.hero__stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.25rem;
  padding: 0.875rem 1.5rem;
}

.hero__stat-value {
  font-size: 1.35rem;
  font-weight: 600;
  color: var(--cream);
  letter-spacing: -0.02em;
}

.hero__stat-label {
  font-size: 0.7rem;
  color: var(--muted-grey);
  letter-spacing: 0.05em;
  white-space: nowrap;
}

.hero__stat-divider {
  width: 1px;
  height: 40px;
  background: var(--border-subtle);
  flex-shrink: 0;
}

/* CTAs */
.hero__ctas {
  display: flex;
  align-items: center;
  gap: 1rem;
  flex-wrap: wrap;
  justify-content: center;
}

.btn--lg {
  padding: 0.8rem 1.75rem;
  font-size: 0.95rem;
  gap: 0.5rem;
}

.btn--outline {
  border: 1px solid var(--border-subtle);
  color: var(--silver);
  background: transparent;
  border-radius: 6px;
  transition: all 0.2s ease;
}

.btn--outline:hover {
  border-color: var(--silver);
  color: var(--cream);
  background: rgba(180, 185, 193, 0.05);
}

/* Terminal */
.hero__terminal {
  width: 100%;
  max-width: 680px;
  background: rgba(10, 13, 16, 0.9);
  border: 1px solid var(--border-subtle);
  border-radius: 12px;
  overflow: hidden;
  text-align: left;
  box-shadow:
    0 0 0 1px rgba(14, 59, 140, 0.1),
    0 24px 60px rgba(0,0,0,0.5),
    0 0 80px rgba(14, 59, 140, 0.06);
  animation: float 5s ease-in-out infinite;
}

.terminal__header {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 0.75rem 1rem;
  background: rgba(17, 27, 36, 0.8);
  border-bottom: 1px solid var(--border-subtle);
}

.terminal__dots {
  display: flex;
  gap: 6px;
}

.terminal__dots span {
  width: 10px;
  height: 10px;
  border-radius: 50%;
}

.terminal__title {
  font-size: 0.72rem;
  color: var(--muted-grey);
  letter-spacing: 0.05em;
}

.terminal__body {
  padding: 1.25rem 1.5rem;
  overflow-x: auto;
}

.terminal__code {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.8rem;
  line-height: 1.8;
  white-space: pre;
  color: var(--cream);
}

/* Syntax colors */
.t-comment { color: #4a5568; }
.t-keyword { color: #7aa2f7; }
.t-fn { color: #73daca; }
.t-type { color: #bb9af7; }
.t-op { color: var(--silver); }
.t-num { color: #ff9e64; }

.t-cursor {
  display: inline-block;
  width: 2px;
  height: 1em;
  background: var(--cobalt-light);
  vertical-align: text-bottom;
  animation: blink 1s step-end infinite;
}

/* Scroll indicator */
.hero__scroll {
  position: absolute;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  opacity: 0.5;
}

.hero__scroll-line {
  width: 1px;
  height: 40px;
  background: linear-gradient(to bottom, var(--cobalt-light), transparent);
  animation: fadeInUp 2s ease-in-out infinite;
}

@media (max-width: 640px) {
  .hero__stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    width: 100%;
  }
  .hero__stat-divider:nth-child(2) { display: none; }
  .hero__stat-divider:nth-child(4) { display: none; }
  .hero__stat-divider {
    width: 100%;
    height: 1px;
    grid-column: 1 / -1;
  }
  .hero__ctas { flex-direction: column; width: 100%; }
  .hero__ctas .btn { width: 100%; justify-content: center; }
}
</style>
