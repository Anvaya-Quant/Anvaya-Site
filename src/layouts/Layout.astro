---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "ANVAYA — Quantum Orchestration & Dev Tools",
  description = "The integrated platform bridging bare-metal quantum control and high-level developer tooling. Build, simulate, and orchestrate quantum circuits at every layer of the stack."
} = Astro.props;

// Import CSS directly — Astro handles bundling
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#0A0D10" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
