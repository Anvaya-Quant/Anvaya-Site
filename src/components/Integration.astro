---
---

<section class="section integration" id="integration">
  <div class="container">

    <div class="section-label">The Innovation</div>
    <div class="integration__header">
      <h2>The Integration Loop.<br/><span class="gradient-text">What Doesn't Exist Yet.</span></h2>
      <p>
        Individual quantum tools exist. An end-to-end integrated stack from
        visual editor to bare-metal pulse controller — with seamless, instant
        data flow between all three — does not.
      </p>
    </div>

    <!-- Flow diagram -->
    <div class="integration__flow">

      <!-- Step 1 -->
      <div class="flow-step" data-step="1">
        <div class="flow-step__num mono">01</div>
        <div class="flow-step__icon">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <rect x="2" y="3" width="24" height="18" rx="2.5" stroke="#1a52c4" stroke-width="1.5"/>
            <path d="M7 9h6M7 13h10M7 17h4" stroke="#1a52c4" stroke-width="1.5" stroke-linecap="round"/>
            <circle cx="19" cy="10" r="4" fill="rgba(14,59,140,0.2)" stroke="#B4B9C1" stroke-width="1"/>
          </svg>
        </div>
        <h4 class="flow-step__title">Design in Studio</h4>
        <p class="flow-step__desc">
          Developer drags quantum gates in ANVAYA Studio. The visual circuit editor
          provides real-time Bloch sphere and probability feedback as each gate is placed.
        </p>
        <div class="flow-step__tag mono">React + TypeScript</div>
      </div>

      <!-- Connector -->
      <div class="flow-connector" aria-hidden="true">
        <div class="flow-connector__line"></div>
        <div class="flow-connector__label mono">OpenQASM</div>
        <svg class="flow-connector__arrow" width="12" height="20" viewBox="0 0 12 20" fill="none">
          <path d="M6 0v16M1 11l5 7 5-7" stroke="#B4B9C1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>

      <!-- Step 2 -->
      <div class="flow-step" data-step="2">
        <div class="flow-step__num mono">02</div>
        <div class="flow-step__icon">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <polygon points="14,2 26,8 26,20 14,26 2,20 2,8" stroke="#B4B9C1" stroke-width="1.5" fill="none"/>
            <polygon points="14,8 20,11 20,17 14,20 8,17 8,11" stroke="#1a52c4" stroke-width="1" fill="rgba(14,59,140,0.2)"/>
            <circle cx="14" cy="14" r="2.5" fill="#1a52c4"/>
          </svg>
        </div>
        <h4 class="flow-step__title">Optimize in Core</h4>
        <p class="flow-step__desc">
          ANVAYA Core (Rust/Wasm) instantly compiles and optimizes the circuit — reducing
          gate depth, merging commuting operations, and running a full local simulation.
        </p>
        <div class="flow-step__tag mono">Rust + WebAssembly</div>
      </div>

      <!-- Connector -->
      <div class="flow-connector" aria-hidden="true">
        <div class="flow-connector__line"></div>
        <div class="flow-connector__label mono">Pulse Sequence</div>
        <svg class="flow-connector__arrow" width="12" height="20" viewBox="0 0 12 20" fill="none">
          <path d="M6 0v16M1 11l5 7 5-7" stroke="#0E3B8C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>

      <!-- Step 3 -->
      <div class="flow-step" data-step="3">
        <div class="flow-step__num mono">03</div>
        <div class="flow-step__icon">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <rect x="2" y="12" width="24" height="4" rx="1" stroke="#0E3B8C" stroke-width="1.2" fill="rgba(14,59,140,0.15)"/>
            <path d="M4 14 L7 9 L10 19 L13 6 L16 22 L19 11 L22 14" stroke="#1a52c4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          </svg>
        </div>
        <h4 class="flow-step__title">Execute via Pulse</h4>
        <p class="flow-step__desc">
          ANVAYA Pulse dispatches the optimized sequence to the quantum processor
          with nanosecond timing. QEC loops run continuously, correcting errors
          in real-time below the decoherence threshold.
        </p>
        <div class="flow-step__tag mono">Embedded Rust + FPGA</div>
      </div>

      <!-- Connector -->
      <div class="flow-connector" aria-hidden="true">
        <div class="flow-connector__line"></div>
        <div class="flow-connector__label mono">Results</div>
        <svg class="flow-connector__arrow" width="12" height="20" viewBox="0 0 12 20" fill="none">
          <path d="M6 0v16M1 11l5 7 5-7" stroke="#1a52c4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>

      <!-- Step 4 -->
      <div class="flow-step" data-step="4">
        <div class="flow-step__num mono">04</div>
        <div class="flow-step__icon">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <path d="M3 20 L7 13 L11 16 L16 8 L20 12 L24 6" stroke="#1a52c4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="24" cy="6" r="2.5" fill="#1a52c4"/>
          </svg>
        </div>
        <h4 class="flow-step__title">Visualize Results</h4>
        <p class="flow-step__desc">
          Measurement results stream back to ANVAYA Studio. Probability histograms,
          state tomography, and error metrics update live in the IDE — closing the loop.
        </p>
        <div class="flow-step__tag mono">React + WebSockets</div>
      </div>

    </div>

    <!-- The differentiator callout -->
    <div class="integration__callout">
      <div class="integration__callout-inner">
        <div class="integration__callout-logo" aria-hidden="true">
          <svg width="56" height="56" viewBox="0 0 56 56" fill="none">
            <ellipse cx="22" cy="28" rx="16" ry="10" stroke="#B4B9C1" stroke-width="1.5" fill="none" transform="rotate(-15 22 28)" opacity="0.8"/>
            <ellipse cx="34" cy="28" rx="16" ry="10" stroke="#B4B9C1" stroke-width="1.5" fill="none" transform="rotate(15 34 28)" opacity="0.8"/>
            <path d="M28 14L36 42H30L28 34L26 42H20L28 14Z" fill="#0E3B8C"/>
            <line x1="22" y1="32" x2="34" y2="32" stroke="#0E3B8C" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="integration__callout-text">
          <h3>The Gap in the Market</h3>
          <p>
            Academic quantum tools give you simulators. Cloud providers give you API access.
            Hardware vendors give you low-level SDKs. <strong style="color:var(--cream)">Nobody gives you the full integrated stack</strong> — from a professional visual editor through a high-performance compiler to deterministic bare-metal control.
            <br/><br/>
            ANVAYA is the Anvaya — the link — that connects them all.
          </p>
        </div>
        <div class="integration__callout-stat">
          <div class="callout-stat">
            <span class="mono" style="font-size:2rem; font-weight:700; color:var(--cream);">0</span>
            <span style="font-size:0.8rem; color:var(--muted-grey);">Existing integrated stacks</span>
          </div>
          <div class="callout-stat" style="margin-top:1.5rem;">
            <span class="mono" style="font-size:2rem; font-weight:700; color:var(--cobalt-light);">1</span>
            <span style="font-size:0.8rem; color:var(--muted-grey);">ANVAYA</span>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
.integration {
  position: relative;
}

.integration__header {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: start;
  margin-bottom: 4rem;
}

.integration__header p {
  padding-top: 0.75rem;
  font-size: 1.05rem;
  line-height: 1.8;
}

/* Flow */
.integration__flow {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
  margin-bottom: 4rem;
  max-width: 600px;
  margin-left: auto;
  margin-right: auto;
}

/* Step */
.flow-step {
  width: 100%;
  background: rgba(17, 27, 36, 0.7);
  border: 1px solid var(--border-subtle);
  border-radius: 12px;
  padding: 1.75rem;
  position: relative;
  transition: all 0.3s ease;
}

.flow-step:hover {
  border-color: rgba(14, 59, 140, 0.3);
  background: rgba(14, 59, 140, 0.05);
}

.flow-step__num {
  position: absolute;
  top: 1.25rem;
  right: 1.25rem;
  font-size: 0.6rem;
  letter-spacing: 0.2em;
  color: var(--border-subtle);
}

.flow-step__icon {
  width: 48px;
  height: 48px;
  background: rgba(14, 59, 140, 0.1);
  border: 1px solid var(--border-cobalt);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 0.875rem;
}

.flow-step__title {
  font-size: 1.05rem;
  font-weight: 600;
  color: var(--cream);
  margin-bottom: 0.6rem;
}

.flow-step__desc {
  font-size: 0.875rem;
  color: var(--muted-grey);
  line-height: 1.7;
  margin-bottom: 0.875rem;
}

.flow-step__tag {
  font-size: 0.65rem;
  letter-spacing: 0.12em;
  color: var(--cobalt-light);
  background: rgba(14, 59, 140, 0.1);
  border: 1px solid rgba(14, 59, 140, 0.2);
  border-radius: 4px;
  padding: 0.2rem 0.6rem;
  display: inline-block;
}

/* Connector */
.flow-connector {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.25rem;
  padding: 0.5rem 0;
}

.flow-connector__line {
  width: 1px;
  height: 20px;
  background: linear-gradient(to bottom, var(--cobalt), var(--silver));
}

.flow-connector__label {
  font-size: 0.6rem;
  letter-spacing: 0.15em;
  color: var(--muted-grey);
}

.flow-connector__arrow { opacity: 0.6; }

/* Callout */
.integration__callout {
  background: rgba(14, 59, 140, 0.06);
  border: 1px solid rgba(14, 59, 140, 0.2);
  border-radius: 16px;
  overflow: hidden;
}

.integration__callout-inner {
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 2.5rem;
  align-items: center;
  padding: 2.5rem;
}

.integration__callout-logo {
  flex-shrink: 0;
  opacity: 0.9;
}

.integration__callout-text h3 {
  font-size: 1.3rem;
  margin-bottom: 0.75rem;
}

.integration__callout-text p {
  font-size: 0.9rem;
  line-height: 1.75;
}

.integration__callout-stat {
  flex-shrink: 0;
  text-align: center;
  padding-left: 2rem;
  border-left: 1px solid var(--border-subtle);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.callout-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.25rem;
}

@media (max-width: 900px) {
  .integration__header {
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  .integration__callout-inner {
    grid-template-columns: 1fr;
    text-align: center;
  }
  .integration__callout-logo { margin: 0 auto; }
  .integration__callout-stat {
    border-left: none;
    border-top: 1px solid var(--border-subtle);
    padding-left: 0;
    padding-top: 1.5rem;
    flex-direction: row;
    gap: 3rem;
  }
}
</style>
